async function fetchEquipment(){
  // If offline flag is set, attempt a lightweight connectivity probe first.
  // This recovers from transient Supabase errors that set offline=true even
  // when the OS-level network never went down (so no "online" event fires).
  if(STATE.offline){
    const canReach=await probeSupabase();
    if(!canReach){
      STATE.equipment=JSON.parse(JSON.stringify(SEED));
      STATE.loading=false;STATE.lastFetch=Date.now();render();return;
    }
    STATE.offline=false; // Supabase is reachable — clear the flag and continue
  }
  try{
    const data=await sb.query("equipment","is_deleted=neq.true&order=last_updated.desc&limit=500");
    if(Array.isArray(data)){
      STATE.equipment=data;
      STATE.offline=false; // Explicit clear on every successful fetch
      // Warn if list is capped — facility may have >500 records
      if(data.length===500){
        showToast("⚠️ Showing first 500 records only — oldest equipment may not be visible","error");
      }
    }else throw new Error("Bad response");
  }catch(e){
    console.warn("Supabase fetch failed, using seed:",e.message);
    STATE.equipment=JSON.parse(JSON.stringify(SEED));STATE.offline=true;
  }
  STATE.loading=false;STATE.lastFetch=Date.now();render();
}

// Lightweight Supabase reachability probe — HEAD request, no auth required
async function probeSupabase(){
  if(!SUPABASE_URL||SUPABASE_URL.includes("YOUR_PROJECT"))return false;
  try{
    const r=await fetch(SUPABASE_URL+"/rest/v1/",{method:"HEAD",signal:AbortSignal.timeout(4000)});
    return r.ok||r.status===401; // 401 = reached Supabase but not authed — that's fine
  }catch{return false;}
}

async function persistEquipment(item){
  if(!canEdit()&&!STATE.offline){showToast("Insufficient permissions","error");throw new Error("Permission denied");}
  // Client-side serial uniqueness guard — catches same-session duplicates
  // and provides a fast, friendly error before hitting the network.
  // The DB UNIQUE constraint on serial_number is the authoritative enforcement.
  const serialLower=item.serial_number.toLowerCase();
  const duplicate=STATE.equipment.find(e=>
    e.serial_number.toLowerCase()===serialLower &&
    e.id!==item.id &&
    !e.is_deleted
  );
  if(duplicate){
    showToast("⚠️ Serial number \""+esc(item.serial_number)+"\" already exists ("+esc(duplicate.name)+")","error");
    throw new Error("Duplicate serial");
  }
  if(STATE.offline){
    const idx=STATE.equipment.findIndex(e=>e.id===item.id);
    idx>=0?(STATE.equipment[idx]=item):STATE.equipment.unshift(item);
    // Queue for sync when back online
    enqueueWrite({type:"upsert",item:{...item}});
    return item;
  }
  try{
    if(item._isNew){const i={...item};delete i._isNew;const r=await sb.insert("equipment",i);return Array.isArray(r)?r[0]:r;}
    const current=STATE.equipment.find(e=>e.id===item.id);
    const knownDate=current?.last_updated||today();
    const r=await sb.safeUpdate("equipment",item.id,item,knownDate);
    if(Array.isArray(r)&&r.length===0){showToast("⚠️ Record changed by another user — refreshing…","error");await fetchEquipment();throw new Error("Conflict");}
    return Array.isArray(r)?r[0]:r;
  }catch(e){
    // Handle Postgres unique constraint violation (serial_number UNIQUE index)
    if(e.message&&(e.message.includes("23505")||e.message.toLowerCase().includes("unique"))){
      showToast("⚠️ Serial number \""+esc(item.serial_number)+"\" already exists in the database","error");
    } else if(e.message!=="Conflict"&&e.message!=="Duplicate serial"){
      showToast("Save failed: "+e.message,"error");
    }
    throw e;
  }
}

async function removeEquipment(id){
  // SOFT DELETE — never permanently destroy records (preserves audit trail)
  const item=STATE.equipment.find(e=>e.id===id);
  if(!item)return;
  const softDeleted={...item,is_deleted:true,last_updated:today()};
  if(STATE.offline){
    STATE.equipment=STATE.equipment.filter(e=>e.id!==id);
    enqueueWrite({type:"delete",id,item:softDeleted});
    return;
  }
  try{
    // Try Edge Function first (adds server-side audit trail beyond DB trigger)
    if(EDGE_URL){
      await sb.edgeSoftDelete(id);
    } else {
      // Fallback: direct REST soft-delete (still protected by RLS)
      await sb.safeUpdate("equipment",id,{is_deleted:true,last_updated:today()},item.last_updated);
    }
    STATE.equipment=STATE.equipment.filter(e=>e.id!==id);
  }catch(e){showToast("Delete failed: "+e.message,"error");throw e;}
}

async function bulkPersist(rows){
  if(STATE.offline){
    rows.forEach(r=>{if(!STATE.equipment.find(e=>e.serial_number.toLowerCase()===r.serial_number.toLowerCase()))STATE.equipment.unshift(r);});
    return{inserted:rows.length,skipped:0};
  }
  try{
    // Try Edge Function first (server-side rate limiting + per-operation audit log)
    if(EDGE_URL){
      const r=await sb.edgeBulkImport(rows);
      return{inserted:r?.inserted||rows.length,skipped:r?.skipped||0,via:"edge"};
    }
    // Fallback: direct REST (still protected by RLS)
    const r=await sb.bulkInsert("equipment",rows);
    const inserted=Array.isArray(r)?r.length:0;
    return{inserted,skipped:rows.length-inserted,via:"rest"};
  }catch(e){showToast("Bulk save failed: "+e.message,"error");throw e;}
}

/* ═══════════════════════════════════════════════════════
   9. REAL-TIME POLLING (multi-user concurrency)
═══════════════════════════════════════════════════════ */
/* ── Supabase Realtime subscription ───────────────────────────
   Replaces inefficient 30s polling with instant push updates.
   Falls back to polling if Realtime is unavailable.
   Reconnect uses exponential backoff — max 5 attempts then
   permanently falls back to polling to avoid memory exhaustion
   on low-RAM devices common in field deployments.
────────────────────────────────────────────────────────────── */
let _realtimeChannel=null;
let _wsAttempts=0;
const WS_MAX_ATTEMPTS=5;
const WS_BACKOFF_MS=[5000,10000,20000,40000,60000]; // caps at 60s

function startRealtime(){
  if(STATE.offline||!SUPABASE_URL.includes("supabase.co"))return startPolling();
  if(_wsAttempts>=WS_MAX_ATTEMPTS){
    // Too many failed attempts — permanent polling fallback to protect low-RAM devices
    console.warn("WebSocket: max reconnect attempts reached, switching to polling permanently");
    return startPolling();
  }
  try{
    // Use Supabase Realtime REST channel (no extra library needed)
    const wsUrl=SUPABASE_URL.replace("https://","wss://")
      +"/realtime/v1/websocket?apikey="+SUPABASE_ANON+"&vsn=1.0.0";
    const ws=new WebSocket(wsUrl);
    ws.onopen=()=>{
      _wsAttempts=0; // Reset backoff counter on successful connection
      // Join the equipment table changes channel
      ws.send(JSON.stringify({
        topic:"realtime:public:equipment",
        event:"phx_join",
        payload:{config:{broadcast:{self:false},presence:{key:""},postgres_changes:[
          {event:"*",schema:"public",table:"equipment"}
        ]}},
        ref:"1"
      }));
    };
    ws.onmessage=async(evt)=>{
      try{
        const msg=JSON.parse(evt.data);
        if(msg.event==="postgres_changes"||msg.payload?.type==="INSERT"||msg.payload?.type==="UPDATE"||msg.payload?.type==="DELETE"){
          // Another user changed equipment — refresh silently
          if(!STATE.modal&&!STATE.detail){
            await fetchEquipment();
            showToast("🔄 Equipment updated","info");
          }
        }
      }catch{}
    };
    ws.onerror=()=>{
      // Graceful fallback to polling if WebSocket fails
      startPolling();
    };
    ws.onclose=()=>{
      // Exponential backoff reconnect — capped at WS_MAX_ATTEMPTS
      const delay=WS_BACKOFF_MS[Math.min(_wsAttempts,WS_BACKOFF_MS.length-1)];
      _wsAttempts++;
      setTimeout(startRealtime,delay);
    };
    _realtimeChannel=ws;
  }catch{
    // Fallback to polling
    startPolling();
  }
}

// Legacy polling fallback (used when Realtime WebSocket unavailable)
function startPolling(){
  if(STATE.pollTimer)return;
  STATE.pollTimer=setInterval(async()=>{
    if(STATE.offline||STATE.loading||STATE.modal||STATE.detail)return;
    try{
      // Use full ISO timestamp (not date-only) — avoids matching records updated
      // earlier the same day, which would cause spurious full-refreshes every 30s
      const since=STATE.lastFetch?new Date(STATE.lastFetch).toISOString():new Date(0).toISOString();
      const r=await sb.query("equipment","last_updated=gte."+encodeURIComponent(since)+"&select=id");
      if(Array.isArray(r)&&r.length>0){await fetchEquipment();showToast("🔄 Equipment updated by another user","info");}
      const prevName=STATE.settings.hospitalName;
      await loadSettingsFromDB();
      if(STATE.settings.hospitalName!==prevName){render();}
    }catch{}
  },30000);
}

