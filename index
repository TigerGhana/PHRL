-- ── 5. DUPLICATE SERIAL NUMBER PROTECTION ─────────────────────
-- The UNIQUE constraint above prevents duplicates at DB level.
-- This function lets the app check before submitting:
CREATE OR REPLACE FUNCTION check_serial_unique(p_serial TEXT, p_exclude_id TEXT DEFAULT NULL)
RETURNS BOOLEAN AS $$
BEGIN
  RETURN NOT EXISTS (
    SELECT 1 FROM equipment
    WHERE serial_number = trim(p_serial)
      AND is_deleted = FALSE
      AND (p_exclude_id IS NULL OR id != p_exclude_id)
  );
END;
$$ LANGUAGE plpgsql;


-- ── 6. ENSURE PROFILE FUNCTION ──────────────────────────────
-- Called by the app on first login to guarantee a profile row exists.
-- Handles the case where the trigger didn't fire (Dashboard user creation).
CREATE OR REPLACE FUNCTION ensure_my_profile(p_email TEXT DEFAULT NULL)
RETURNS TEXT AS $$
DECLARE
  v_email TEXT;
  v_role  TEXT;
BEGIN
  -- Get email from auth if not passed
  v_email := COALESCE(p_email, auth.jwt()->>'email', 'unknown@hospital.com');

  -- Insert profile if it doesn't exist
  INSERT INTO profiles (id, email, role)
  VALUES (auth.uid(), v_email, 'viewer')
  ON CONFLICT (id) DO NOTHING;

  -- Return the role
  SELECT role INTO v_role FROM profiles WHERE id = auth.uid();
  RETURN COALESCE(v_role, 'viewer');
END;
$$ LANGUAGE plpgsql SECURITY DEFINER SET search_path = public;

