async function doLogin(email,pw){
  const rateCheck=checkRate();if(!rateCheck.ok)return{ok:false,msg:rateCheck.msg};
  const e2=san.email(email);
  if(!V.email(e2))return{ok:false,msg:"Enter a valid email address."};
  if(!pw||pw.length<6||pw.length>200)return{ok:false,msg:"Password must be 6–200 characters."};
  if(STATE.offline){
    // DEMO/OFFLINE MODE: Only active when SUPABASE_URL is not configured.
    // This code path MUST be removed or disabled before any production deployment.
    // Do not deploy this app with YOUR_PROJECT still in the URL.
    if(!SUPABASE_URL.includes("YOUR_PROJECT")){
      // Supabase is configured but we somehow ended up offline — fail safely
      return{ok:false,msg:"Cannot authenticate: no network connection to Supabase."};
    }
    const sess={access_token:"demo_"+uid(),user:{email:e2,id:"demo-user"}};
    STATE.adminSession=sess;STATE.adminEmail=e2;saveS("medinv_admin",sess);return{ok:true};
  }
  try{
    // Get hCaptcha token if widget is mounted
    let captchaToken="";
    if(HCAPTCHA_SITE_KEY){
      try{
        const resp=hcaptcha.getResponse();
        if(!resp){showToast("Please complete the captcha","error");if(btn){btn.disabled=false;btn.textContent="Login";}return{ok:false,msg:"Captcha required."};}
        captchaToken=resp;
      }catch{/* hCaptcha not loaded — proceed without */}
    }
    const r=await sb.signIn(e2,pw,captchaToken);
    if(r?.access_token){STATE.adminSession=r;STATE.adminEmail=r.user?.email||e2;saveS("medinv_admin",r);recordLoginSuccess();return{ok:true};}
    return{ok:false,msg:r?.error_description||r?.message||"Invalid credentials."};
  }catch(e){return{ok:false,msg:"Login error: "+e.message};}
}
async function doLogout(){
  if(STATE.adminSession?.access_token&&!STATE.offline)try{await sb.signOut(STATE.adminSession.access_token);}catch{}
  STATE.adminSession=null;STATE.adminEmail="";STATE.verifiedRole="";
  sessionStorage.removeItem("medinv_admin");
  sessionStorage.removeItem("medinv_role");
}

/* ═══════════════════════════════════════════════════════
   10b. SETTINGS SYNC (Supabase ↔ all devices)
   Settings are stored in a Supabase 'settings' table
   so changes on one device appear on all others.
   localStorage is used as an offline fallback only.
═══════════════════════════════════════════════════════ */
async function loadSettingsFromDB(){
  if(STATE.offline)return; // use localStorage fallback
  try{
    const rows=await sb.getSettings();
    if(!Array.isArray(rows))return;
    const map={};
    rows.forEach(r=>{try{map[r.key]=JSON.parse(r.value);}catch{map[r.key]=r.value;}});
    // Merge into STATE.settings (Supabase wins over localStorage)
    if(map.hospitalName)   STATE.settings.hospitalName=map.hospitalName;
    if(map.reminders!==undefined) STATE.settings.reminders=map.reminders;
    if(map.calThreshold)   STATE.settings.calThreshold=map.calThreshold;
    if(map.categories&&Array.isArray(map.categories)) STATE.settings.categories=map.categories;
    if(map.locations&&Array.isArray(map.locations))   STATE.settings.locations=map.locations;
    // Write merged result to localStorage as cache
    saveP("medinv_settings",STATE.settings);
  }catch(e){console.warn("Settings load failed:",e.message);}
}

async function saveSettingToDB(key,value){
  // Always write to localStorage first (instant, offline-safe)
  STATE.settings[key]=value;
  saveP("medinv_settings",STATE.settings);
  // Then sync to Supabase (admin only — enforced by RLS)
  if(!STATE.offline){
    try{
      // Try Edge Function first — provides server-side validation + logging
      if(EDGE_URL){
        const r=await sb.edgeSetSetting(key,value);
        if(r===null)await sb.setSetting(key,value); // null means Edge not deployed yet
      } else {
        await sb.setSetting(key,value);
      }
    }catch(e){
      // Fallback to direct REST
      try{await sb.setSetting(key,value);}
      catch(e2){console.warn("Setting sync failed:",e2.message);}
    }
  }
}

