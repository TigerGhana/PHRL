function render(){
  const app=document.getElementById("app");if(!app)return;
  document.getElementById("offline-bar").style.display=STATE.offline?"block":"none";
  if(STATE.loading){
    app.innerHTML='<div style="display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:100vh;gap:16px;background:var(--bg);width:100%"><div style="font-size:56px;animation:pulse 1.5s infinite">🏥</div><div style="font-weight:900;color:var(--teal);font-size:18px">Loading MedEquip…</div><style>@keyframes pulse{0%,100%{transform:scale(1)}50%{transform:scale(1.06)}}</style></div>';
    return;
  }
  const fns={home:renderHome,equipment:renderEquipment,maintenance:renderMaintenance,reports:renderReports,settings:renderSettings};
  const screen=(fns[STATE.tab]||renderHome)();
  const nav=renderNav();
  const sidebar=renderSidebar();
  const modal=STATE.modal?renderModal():"";
  const detail=STATE.detail?renderDetail():"";
  const report=STATE.report?renderReportDetail():"";
  app.innerHTML=sidebar+'<div id="main-content">'+screen+nav+'</div>'+modal+detail+report;
  bindEvents();
  if(STATE.report)renderChart();
}

