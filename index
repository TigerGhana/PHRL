<style>
*{box-sizing:border-box;-webkit-tap-highlight-color:transparent;margin:0;padding:0}
html{-webkit-text-size-adjust:100%}
body{font-family:'Nunito',sans-serif;background:#8faab5;min-height:100vh;display:flex;justify-content:flex-start;overscroll-behavior:none}
:root{
  --teal:#1a8fa0;--teal-dk:#14717f;--teal-lt:#e6f6f8;--teal-mid:#c0e8ef;
  --green:#22c55e;--green-lt:#dcfce7;--green-dk:#16a34a;
  --red:#ef4444;--red-lt:#fee2e2;
  --amber:#f59e0b;--amber-lt:#fef3c7;
  --blue:#3b82f6;--blue-lt:#dbeafe;
  --orange:#f97316;
  --bg:#f0f4f6;--card:#ffffff;--text:#1e293b;--sub:#64748b;--border:#e2e8f0;
  --shadow:0 2px 12px rgba(0,0,0,.08);--shadow-lg:0 8px 32px rgba(0,0,0,.14);
}
/* ── Base (mobile-first) ───────────────────────── */
#app{width:100%;min-height:100vh;background:var(--bg);display:flex;flex-direction:column}
#sidebar{display:none}
#main-content{flex:1;display:flex;flex-direction:column;min-width:0;position:relative}

/* ── Mobile ≤599px ─────────────────────────────── */
@media(max-width:599px){
  body{justify-content:center}
  #app{max-width:430px}
}

/* ── Tablet 600–899px ──────────────────────────── */
@media(min-width:600px) and (max-width:899px){
  body{background:#dde8ed;justify-content:center}
  #app{max-width:680px;box-shadow:0 0 40px rgba(0,0,0,.2)}
  .page-hero{padding:28px 28px 24px}
  .page-hero h1{font-size:26px}
}

/* ── Desktop ≥900px ────────────────────────────── */
@media(min-width:900px){
  body{background:#dde8ed;justify-content:center;align-items:flex-start}
  #app{flex-direction:row;max-width:1320px;min-height:100vh;box-shadow:0 0 60px rgba(0,0,0,.2)}

  /* Sidebar */
  #sidebar{
    display:flex;flex-direction:column;
    width:230px;flex-shrink:0;
    background:var(--teal-dk);
    min-height:100vh;
    padding:28px 0 20px;
    position:sticky;top:0;height:100vh;overflow-y:auto;
  }

  /* Main content fills the rest */
  #main-content{flex:1;min-width:0;min-height:100vh;overflow-x:hidden}

  /* Bottom nav hidden on desktop */
  .bnav{display:none!important}

  /* Screen padding */
  .screen{padding-bottom:32px!important}
  .page-hero{padding:32px 40px 28px}
  .page-hero h1{font-size:28px}

  /* Tiles bigger */
  .tile{padding:22px 18px 26px}

  /* Full-screen slides cover only the main content area */
  .fullscreen{
    position:fixed;
    top:0;bottom:0;
    left:230px;right:0;
    transform:none;
    max-width:none;
    width:auto;
    z-index:50;
  }

  /* Modal overlay: covers main content only */
  .overlay{
    position:fixed;
    top:0;bottom:0;
    left:230px;right:0;
    transform:none;
    align-items:center;   /* center vertically on desktop */
    justify-content:center;
    z-index:100;
  }

  /* Modal box: centered, not bottom-sheet on desktop */
  .mbox{
    width:100%;
    max-width:560px;
    max-height:90vh;
    border-radius:18px;   /* fully rounded on desktop */
    align-self:auto;
    margin:0;
  }

  /* Offline bar covers main area */
  #offline-bar{
    position:fixed;
    top:0;
    left:230px;right:0;
    transform:none;
    max-width:none;
    width:auto;
  }
}

/* ── Wide desktop ≥1200px ──────────────────────── */
@media(min-width:1200px){
  #sidebar{width:260px}
  .fullscreen{left:260px}
  .overlay{left:260px}
  #offline-bar{left:260px}
  #app{max-width:1440px}
}
.screen{flex:1;overflow-y:auto;padding-bottom:88px;animation:fadeUp .2s ease both}
@keyframes fadeUp{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}

/* ── Nav ── */
.bnav{position:fixed;bottom:0;left:50%;transform:translateX(-50%);width:100%;max-width:430px;background:var(--card);border-top:1px solid var(--border);display:flex;z-index:40;padding-bottom:env(safe-area-inset-bottom,0px);box-shadow:0 -4px 20px rgba(0,0,0,.07)}
@media(min-width:600px) and (max-width:899px){.bnav{max-width:680px}}
.nbtn{flex:1;background:none;border:none;padding:10px 2px 8px;cursor:pointer;display:flex;flex-direction:column;align-items:center;gap:2px;user-select:none;position:relative}
.nbtn .ico{font-size:19px;line-height:1;filter:grayscale(1) opacity(.35);transition:filter .15s}
.nbtn .lbl{font-size:9.5px;font-weight:700;letter-spacing:.3px;color:var(--sub);font-family:'Nunito',sans-serif}
.nbtn.active .ico{filter:none}
.nbtn.active .lbl{color:var(--teal)}
.nbtn.active::after{content:'';position:absolute;top:0;left:50%;transform:translateX(-50%);width:28px;height:3px;background:var(--teal);border-radius:0 0 4px 4px}

/* ── Cards ── */
.card{background:var(--card);border-radius:16px;box-shadow:var(--shadow)}
.tile{background:var(--card);border-radius:16px;padding:18px 14px 22px;box-shadow:var(--shadow);position:relative;overflow:hidden;cursor:pointer;transition:transform .12s;-webkit-user-select:none}
.tile:active{transform:scale(.96)}
.tile-bar{position:absolute;bottom:0;left:0;right:0;height:5px}
.eq-card{background:var(--card);border-radius:14px;padding:15px;box-shadow:var(--shadow);cursor:pointer;border-left:4px solid var(--border);transition:transform .12s}
.eq-card:active{transform:scale(.975)}

/* ── Status label row ── */
.status-label{font-size:9px;font-weight:800;color:var(--sub);text-transform:uppercase;letter-spacing:.8px;margin-bottom:3px}
.badge{display:inline-flex;align-items:center;font-size:10.5px;font-weight:800;border-radius:99px;padding:4px 10px;white-space:nowrap;line-height:1.4;letter-spacing:.2px}

/* ── Buttons ── */
.btn{font-family:'Nunito',sans-serif;font-weight:700;font-size:14px;border-radius:12px;border:none;cursor:pointer;padding:12px 14px;transition:opacity .15s,transform .1s;width:100%;display:flex;align-items:center;justify-content:center;gap:6px;user-select:none}
.btn:active{opacity:.82;transform:scale(.98)}
.btn:disabled{opacity:.5;cursor:not-allowed}
.btn-teal{background:var(--teal);color:#fff}
.btn-outline{background:var(--card);color:var(--text);border:1.5px solid var(--border)}
.btn-ghost{background:transparent;color:var(--teal);border:1.5px solid var(--teal-mid)}
.btn-red{background:var(--red);color:#fff}
.btn-amber{background:var(--amber);color:#fff}

/* ── Inputs ── */
.inp{font-family:'Nunito',sans-serif;font-size:14px;padding:11px 13px;border-radius:11px;border:1.5px solid var(--border);outline:none;width:100%;color:var(--text);background:#fff;transition:border .15s,box-shadow .15s;-webkit-appearance:none}
.inp:focus{border-color:var(--teal);box-shadow:0 0 0 3px rgba(26,143,160,.12)}
.inp.err{border-color:var(--red)}
input[type=date].inp{color-scheme:light}
.field-err{font-size:11px;color:var(--red);display:none;margin-top:3px;font-weight:600}

/* ── Modal ── */
.overlay{position:fixed;inset:0;background:rgba(0,0,0,.55);display:flex;align-items:flex-end;justify-content:center;z-index:100;animation:fadeIn .15s ease;backdrop-filter:blur(3px)}
.mbox{background:var(--card);border-radius:24px 24px 0 0;width:100%;max-width:430px;max-height:96vh;overflow-y:auto;padding:22px 18px 36px;display:flex;flex-direction:column;gap:13px;animation:slideUp .22s ease}
@keyframes fadeIn{from{opacity:0}to{opacity:1}}
@keyframes slideUp{from{transform:translateY(44px);opacity:0}to{transform:translateY(0);opacity:1}}

/* ── Full-screen slide ── */
.fullscreen{position:fixed;inset:0;background:var(--bg);z-index:50;overflow-y:auto;max-width:430px;left:50%;transform:translateX(-50%);display:flex;flex-direction:column;animation:slideRight .22s ease both}
@media(min-width:600px) and (max-width:899px){.fullscreen{max-width:680px}}
@keyframes slideRight{from{opacity:0;transform:translateX(calc(50% + 24px))}to{opacity:1;transform:translateX(-50%)}}
.fs-header{background:var(--card);padding:14px 18px;display:flex;align-items:center;gap:12px;box-shadow:var(--shadow);position:sticky;top:0;z-index:10}
.fs-back{background:var(--teal-lt);border:none;cursor:pointer;color:var(--teal);font-family:'Nunito',sans-serif;padding:7px 12px;border-radius:10px;font-weight:700;font-size:14px}

/* ── Page hero ── */
.page-hero{background:linear-gradient(135deg,var(--teal) 0%,var(--teal-dk) 100%);padding:26px 20px 22px;color:#fff}
.page-hero h1{font-size:24px;font-weight:900;color:#fff;line-height:1.1}
.page-hero p{font-size:11px;font-weight:700;letter-spacing:1.5px;opacity:.8;text-transform:uppercase;margin-top:4px}

/* ── Content padding (adapts per screen size) ── */
.content-pad{padding:16px;display:flex;flex-direction:column}
@media(min-width:900px){.content-pad{padding:24px 36px}}
@media(min-width:600px) and (max-width:899px){.content-pad{padding:20px 24px}}

/* ── Misc ── */
.sec-lbl{font-size:10px;font-weight:800;letter-spacing:1.5px;color:var(--sub);text-transform:uppercase}
.ro-notice{background:#f8fafc;border:1.5px dashed var(--border);border-radius:11px;padding:11px 13px;display:flex;align-items:center;gap:10px;font-size:12.5px;color:var(--sub);font-weight:600}
.mcard-red{background:#fff5f5;border:1.5px solid var(--red);border-radius:14px;padding:14px;display:flex;flex-direction:column;gap:8px}
.mcard-amb{background:#fffbeb;border:1.5px solid var(--amber);border-radius:14px;padding:14px;display:flex;flex-direction:column;gap:8px}
.mcard-grn{background:var(--green-lt);border:1.5px solid var(--green);border-radius:14px;padding:16px;text-align:center;color:var(--green-dk);font-weight:700;font-size:14px}
.toggle{width:46px;height:26px;border-radius:13px;cursor:pointer;position:relative;transition:background .2s;flex-shrink:0}
.toggle-thumb{position:absolute;top:3px;width:20px;height:20px;border-radius:10px;background:#fff;transition:left .2s;box-shadow:0 1px 5px rgba(0,0,0,.22)}
.info-row{display:flex;align-items:flex-start;gap:12px;padding:13px 0;border-bottom:1px solid var(--border)}
.info-row:last-child{border-bottom:none}
.info-icon{width:34px;height:34px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:17px;flex-shrink:0}
.search-wrap{position:relative}
.search-wrap::before{content:"🔍";position:absolute;left:12px;top:50%;transform:translateY(-50%);font-size:13px;z-index:1;pointer-events:none}
.search-wrap input{padding-left:36px}
.report-row{padding:14px 16px;border-radius:14px;background:var(--card);box-shadow:var(--shadow);display:flex;align-items:center;gap:12px;cursor:pointer;transition:transform .12s}
.report-row:active{transform:scale(.975)}
#offline-bar{position:fixed;top:0;left:50%;transform:translateX(-50%);width:100%;max-width:430px;background:#f97316;color:#fff;font-size:11px;font-weight:700;text-align:center;padding:6px;z-index:200;display:none}
@media(min-width:600px) and (max-width:899px){#offline-bar{max-width:680px}}
::-webkit-scrollbar{width:3px}
::-webkit-scrollbar-thumb{background:var(--border);border-radius:4px}
#sync-bar{position:fixed;bottom:72px;left:50%;transform:translateX(-50%);background:#1e293b;color:#fff;font-size:12px;font-weight:700;padding:8px 18px;border-radius:99px;z-index:500;display:none;align-items:center;gap:8px;box-shadow:0 4px 14px rgba(0,0,0,.25);font-family:'Nunito',sans-serif;white-space:nowrap}
@media(min-width:900px){#sync-bar{bottom:20px;left:calc(230px + 50%);transform:translateX(-50%)}}
</style>
