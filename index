    on("btn-print-qr",()=>{
      // Extract QR as a data URL from the canvas — never inject raw innerHTML
      // into a new window (avoids XSS via DOM manipulation or browser extensions)
      const canvas=document.getElementById("qr-canvas-wrap")?.querySelector("canvas");
      if(!canvas){showToast("QR not ready — try again in a moment","error");return;}
      const dataUrl=canvas.toDataURL("image/png");
      const win=window.open("","_blank");
      if(!win){showToast("Pop-up blocked — allow pop-ups for this site","error");return;}
      // All content is either escaped text or a safe data: URI — no raw HTML injection
      win.document.write(
        '<!DOCTYPE html><html><head><title>QR \u2014 '+esc(STATE.qrItem.name)+'</title>'+
        '<style>body{font-family:sans-serif;text-align:center;padding:40px}h2{margin-bottom:4px}p{color:#64748b;font-size:13px}img{display:block;margin:16px auto}</style>'+
        '</head><body>'+
        '<h2>'+esc(STATE.qrItem.name)+'</h2>'+
        '<p>SN: '+esc(STATE.qrItem.serial_number)+' | '+esc(STATE.qrItem.location)+'</p>'+
        '<img src="'+dataUrl+'" alt="QR code" width="200" height="200"/>'+
        '<p style="margin-top:12px">Next Maintenance: '+esc(STATE.qrItem.next_maintenance)+'</p>'+
        '<script>window.print();window.close();<\/script>'+
        '</body></html>');
      win.document.close();
    });
    on("btn-download-qr",()=>{
      const canvas=document.getElementById("qr-code-output")?.querySelector("canvas");
      if(!canvas){showToast("QR not ready — try again in a moment","error");return;}
      const a=document.createElement("a");
      a.href=canvas.toDataURL("image/png");
      a.download="QR-"+san.serial(STATE.qrItem.serial_number||"equip")+".png";
      a.click();
      showToast("QR code saved ✓","success");
    });
  }
}

async function handleLogin(){
  const email=san.email(document.getElementById("inp-email")?.value||"");
  const pass=san.text(document.getElementById("inp-password")?.value||"");
  const errEl=document.getElementById("login-error");
  const btn=document.getElementById("btn-do-login");
  if(errEl)errEl.style.display="none";
  const preCheck=checkRate();
  if(!preCheck.ok){
    if(errEl){errEl.textContent=preCheck.msg;errEl.style.display="block";}
    if(btn){btn.disabled=true;let t=preCheck.wait;const cd=setInterval(()=>{if(t<=0){clearInterval(cd);btn.disabled=false;btn.textContent="Login";return;}btn.textContent="Wait "+t+"s…";t--;},1000);}
    return;
  }
  if(btn){btn.disabled=true;btn.textContent="Verifying…";}
  const res=await doLogin(email,pass);
  if(res.ok){
    STATE.modal=null;
    // Verify role from DB — never trust client-side state alone
    if(!STATE.offline){
      try{
        // get_my_role() RPC returns a scalar string e.g. "admin"
        const rr=await sb.getMyRole(STATE.adminEmail);
        // RPC scalar comes back as raw string or {"get_my_role":"admin"}
        let dbRole="viewer";
        if(typeof rr==="string")dbRole=rr;
        else if(rr&&typeof rr==="object"&&rr.get_my_role)dbRole=rr.get_my_role;
        // Validate the role is a known value
        if(!["admin","engineer","technician","viewer"].includes(dbRole))dbRole="viewer";
        STATE.verifiedRole=dbRole;
        saveS("medinv_role",dbRole);
        const roleEmoji={admin:"🔴",engineer:"🔵",technician:"🟡",viewer:"🟢"}[dbRole]||"⚪";
        showToast("Welcome "+esc(STATE.adminEmail)+" "+roleEmoji+" "+dbRole+" ✓","success");
      }catch(e){
        // If role fetch fails, default to viewer (fail-safe)
        STATE.verifiedRole="viewer";saveS("medinv_role","viewer");
        showToast("Logged in — could not verify role (defaulting to viewer)","error");
        console.warn("Role fetch failed:",e.message);
      }
    } else {
      // Demo/offline mode — admin only for testing
      STATE.verifiedRole="admin";saveS("medinv_role","admin");
      showToast("Welcome "+esc(STATE.adminEmail)+" [Demo] ✓","success");
    }
    render();
  }
  else{recordLoginFailure();if(errEl){errEl.textContent=res.msg;errEl.style.display="block";}if(btn){btn.disabled=false;btn.textContent="Login";}}
}

async function handleSaveEq(){
  if(!canEdit()){showToast("Admin or Engineer role required","error");return;}
  function showFE(id,msg){const el=document.getElementById(id);if(el)el.classList.add("err");const e=document.getElementById("err-"+id);if(e){e.textContent=msg;e.style.display="block";}}
  function clearFE(){document.querySelectorAll(".inp.err").forEach(el=>el.classList.remove("err"));document.querySelectorAll(".field-err").forEach(el=>{el.style.display="none";el.textContent="";});}
  clearFE();
  const name   =san.name(document.getElementById("inp-name")?.value||"");
  const serial =san.serial(document.getElementById("inp-serial")?.value||"");
  const maint  =san.date(document.getElementById("inp-maint")?.value||"");
  const rawCat =san.text(document.getElementById("inp-category")?.value||"");
  const rawLoc =san.text(document.getElementById("inp-location")?.value||"");
  const rawStat=san.text(document.getElementById("inp-status")?.value||"");
  const calStatVal=san.text(document.getElementById("inp-cal-status")?.value||"cal_not_required");
  const lastCal=san.date(document.getElementById("inp-last-cal")?.value||"")||null;
  const nextCal=san.date(document.getElementById("inp-next-cal")?.value||"")||null;
  const _rawMaint=san.num(document.getElementById("inp-maint-interval")?.value||DEFAULT_RECURRENCE);
  const maintInterval=(_rawMaint>0?_rawMaint:parseInt(DEFAULT_RECURRENCE)).toString();
  const _rawCal=san.num(document.getElementById("inp-cal-interval")?.value||DEFAULT_CAL_RECURRENCE);
  const calInterval=(_rawCal>0?_rawCal:parseInt(DEFAULT_CAL_RECURRENCE)).toString();
  const notes  =san.notes(document.getElementById("inp-notes")?.value||"");
  let ok=true;
  if(!V.name(name))                  {showFE("inp-name","Name must be 2–120 characters.");ok=false;}
  if(!V.serial(serial))              {showFE("inp-serial","Use 1–60 alphanumeric / - _ . / chars.");ok=false;}
  if(!V.date(maint))                 {showFE("inp-maint","Select a valid date (YYYY-MM-DD).");ok=false;}
  if(!V.status(rawStat))             {showFE("inp-status","Invalid functional status.");ok=false;}
  if(!V.calStatus(calStatVal))       {showFE("inp-cal-status","Invalid calibration status.");ok=false;}
  if(!getCategories().includes(rawCat)){showFE("inp-category","Select a valid category.");ok=false;}
  if(!getLocations().includes(rawLoc)) {showFE("inp-location","Select a valid location.");ok=false;}
  if(calStatVal==="cal_required"){
    if(lastCal&&!V.date(lastCal))    {showFE("inp-last-cal","Enter a valid date (YYYY-MM-DD).");ok=false;}
    if(!nextCal)                     {showFE("inp-next-cal","Next Calibration Date is required.");ok=false;}
    else if(!V.date(nextCal))        {showFE("inp-next-cal","Enter a valid date (YYYY-MM-DD).");ok=false;}
  }
  if(!ok)return;
  const isEdit=STATE.modal&&STATE.modal!=="add";
  const item={id:isEdit?STATE.modal.id:uid(),name,category:rawCat,serial_number:serial,location:rawLoc,status:rawStat,next_maintenance:maint,calibration_status:calStatVal,last_calibration:calStatVal==="cal_required"?lastCal:null,next_calibration:calStatVal==="cal_required"?nextCal:null,maintenance_interval:maintInterval,calibration_interval:calStatVal==="cal_required"?calInterval:null,notes,last_updated:today(),...(isEdit?{}:{_isNew:true})};
  const btn=document.getElementById("btn-save-eq");
  if(btn){btn.disabled=true;btn.textContent="Saving…";}
  try{await persistEquipment(item);STATE.modal=null;await fetchEquipment();showToast(isEdit?"Equipment updated ✓":"Equipment added ✓","success");}
  catch{
    if(btn){btn.disabled=false;btn.textContent="💾 "+(isEdit?"Update":"Add")+" Equipment";}
    const sb2=document.getElementById("btn-save-eq");
    if(sb2)delete sb2.dataset.submitting;
  }
}

async function handleDeleteEq(){
  if(!isAdmin()){showToast("Admin role required to delete","error");return;}
  if(STATE.modal==="add"||!STATE.modal)return;
  if(!confirm("Delete \""+san.text(STATE.modal.name)+"\"? This cannot be undone."))return;
  try{await removeEquipment(STATE.modal.id);STATE.modal=null;render();showToast("Equipment deleted","info");}catch{}
}

