-- ── 3. EQUIPMENT TABLE ────────────────────────────────────────
CREATE TABLE IF NOT EXISTS equipment (
  id                 TEXT        PRIMARY KEY DEFAULT gen_random_uuid()::text,
  name               TEXT        NOT NULL CHECK(length(trim(name)) >= 2),
  category           TEXT        NOT NULL,
  serial_number      TEXT        NOT NULL,
  location           TEXT        NOT NULL,
  status             TEXT        NOT NULL DEFAULT 'functional_in_use'
                       CHECK(status IN (
                         'functional_in_use','functional_not_in_use',
                         'non_functional','needs_repair','obsolete'
                       )),
  next_maintenance   DATE        NOT NULL,
  calibration_status TEXT        NOT NULL DEFAULT 'cal_not_required'
                       CHECK(calibration_status IN ('cal_required','cal_not_required')),
  last_calibration   DATE,
  next_calibration   DATE,
  notes                  TEXT    NOT NULL DEFAULT '',
  maintenance_interval   TEXT    DEFAULT '90',   -- days: 30/60/90/180/365/730/0
  calibration_interval   TEXT    DEFAULT '365',  -- days: 90/180/365/730/0
  is_deleted             BOOLEAN NOT NULL DEFAULT FALSE,
  last_updated           DATE    NOT NULL DEFAULT CURRENT_DATE,
  created_by             UUID    REFERENCES auth.users(id),
  CONSTRAINT unique_serial UNIQUE(serial_number),
  CONSTRAINT chk_cal_dates CHECK (
    calibration_status = 'cal_not_required'
    OR (calibration_status = 'cal_required' AND next_calibration IS NOT NULL)
  )
);

