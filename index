function parseBulkFile(file){
  if(!file)return;
  const allowed=["application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
    "application/vnd.ms-excel","text/csv","application/csv"];
  const ext=file.name.split(".").pop().toLowerCase();
  if(!allowed.includes(file.type)&&!["xlsx","xls","csv"].includes(ext)){
    showToast("Only Excel (.xlsx/.xls) or CSV files are allowed","error");return;
  }
  if(file.size>5*1024*1024){showToast("File too large (max 5MB)","error");return;}

  /* ── Smart date normaliser ──────────────────────────────────
     Accepts: YYYY-MM-DD, DD/MM/YYYY, MM/DD/YYYY, D-M-YYYY,
              "April 10, 2026", Excel serial numbers, ISO with time
  ───────────────────────────────────────────────────────────── */
  function normaliseDate(raw){
    if(!raw)return"";
    const s=String(raw).trim();
    if(!s||s.toLowerCase()==="n/a"||s.toLowerCase()==="none")return"";

    // Already YYYY-MM-DD
    if(/^\d{4}-\d{2}-\d{2}$/.test(s))return s;

    // YYYY-MM-DD with time suffix e.g. "2026-04-10 00:00:00" or "2026-04-10T..."
    const dtMatch=s.match(/^(\d{4}-\d{2}-\d{2})[T ]/);
    if(dtMatch)return dtMatch[1];

    // Excel numeric serial date (e.g. 46200)
    if(/^\d{4,6}$/.test(s)){
      const n=parseInt(s);
      if(n>10000&&n<100000){
        const d=new Date((n-25569)*86400000);
        return d.toISOString().slice(0,10);
      }
    }

    // DD/MM/YYYY or MM/DD/YYYY — try both and pick the valid one
    const slash=s.match(/^(\d{1,2})[\/\-](\d{1,2})[\/\-](\d{4})$/);
    if(slash){
      const [,a,b,y]=slash;
      // If first part > 12, must be DD/MM
      if(parseInt(a)>12){
        const d=new Date(y+"-"+b.padStart(2,"0")+"-"+a.padStart(2,"0"));
        if(!isNaN(d))return d.toISOString().slice(0,10);
      }
      // Try MM/DD/YYYY first (US format)
      const us=new Date(y+"-"+a.padStart(2,"0")+"-"+b.padStart(2,"0"));
      if(!isNaN(us))return us.toISOString().slice(0,10);
    }

    // "April 10, 2026" or "10 April 2026"
    const parsed=new Date(s);
    if(!isNaN(parsed)&&parsed.getFullYear()>2000)return parsed.toISOString().slice(0,10);

    return""; // Could not parse
  }

  /* ── Smart status normaliser ────────────────────────────────
     Maps labels and variations → internal key
  ───────────────────────────────────────────────────────────── */
  const STATUS_ALIASES={
    "functional_in_use":"functional_in_use",
    "functional & in use":"functional_in_use",
    "functional and in use":"functional_in_use",
    "functional - in use":"functional_in_use",
    "in use":"functional_in_use",
    "functional":"functional_in_use",
    "functional_not_in_use":"functional_not_in_use",
    "functional but not in use":"functional_not_in_use",
    "functional not in use":"functional_not_in_use",
    "not in use":"functional_not_in_use",
    "standby":"functional_not_in_use",
    "non_functional":"non_functional",
    "non-functional":"non_functional",
    "non functional":"non_functional",
    "not working":"non_functional",
    "broken":"non_functional",
    "faulty":"non_functional",
    "needs_repair":"needs_repair",
    "needs repair":"needs_repair",
    "needs service":"needs_repair",
    "under repair":"needs_repair",
    "repair":"needs_repair",
    "obsolete":"obsolete",
    "condemned":"obsolete",
    "decommissioned":"obsolete",
    "disposed":"obsolete",
    "written off":"obsolete",
  };
  function normaliseStatus(raw){
    const s=String(raw||"").toLowerCase().trim().replace(/\s+/g," ");
    return STATUS_ALIASES[s]||s.replace(/[\s\-]+/g,"_");
  }

  /* ── Smart calibration status normaliser ────────────────────
  ───────────────────────────────────────────────────────────── */
  const CAL_ALIASES={
    "cal_required":"cal_required",
    "calibration required":"cal_required",
    "required":"cal_required",
    "yes":"cal_required",
    "y":"cal_required",
    "true":"cal_required",
    "1":"cal_required",
    "cal_not_required":"cal_not_required",
    "calibration not required":"cal_not_required",
    "not required":"cal_not_required",
    "no":"cal_not_required",
    "n":"cal_not_required",
    "false":"cal_not_required",
    "0":"cal_not_required",
    "none":"cal_not_required",
    "n/a":"cal_not_required",
  };
  function normaliseCalStatus(raw){
    const s=String(raw||"").toLowerCase().trim();
    return CAL_ALIASES[s]||s.replace(/\s+/g,"_");
  }

  /* ── Smart category/location matcher ────────────────────────
     Case-insensitive, trim, partial match allowed
  ───────────────────────────────────────────────────────────── */
  function matchList(value, list){
    const v=String(value||"").trim().toLowerCase();
    if(!v)return null;
    // Exact match first
    const exact=list.find(l=>l.toLowerCase()===v);
    if(exact)return exact;
    // Partial match (starts with)
    const partial=list.find(l=>l.toLowerCase().startsWith(v)||v.startsWith(l.toLowerCase()));
    if(partial)return partial;
    // Contains match
    const contains=list.find(l=>l.toLowerCase().includes(v)||v.includes(l.toLowerCase()));
    return contains||null;
  }

  const reader=new FileReader();
  reader.onload=e=>{
    try{
      const data=new Uint8Array(e.target.result);
      const wb=XLSX.read(data,{type:"array",cellDates:false});
      const ws=wb.Sheets[wb.SheetNames[0]];
      const raw=XLSX.utils.sheet_to_json(ws,{header:1,raw:false});
      if(!raw||raw.length<2){showToast("File is empty or unreadable","error");return;}

      // Find header row (row containing "name" in col A, case-insensitive)
      let headerIdx=0;
      for(let i=0;i<Math.min(5,raw.length);i++){
        if(String(raw[i][0]||"").toLowerCase().trim()==="name"){headerIdx=i;break;}
      }
      const dataRows=raw.slice(headerIdx+1);
      const cats=getCategories();
      const locs=getLocations();

      const valid=[],errors=[],warnings=[];

      dataRows.forEach((row,ri)=>{
        if(!row||row.every(c=>!String(c||"").trim()))return;
        const rn=headerIdx+ri+2;
        const rowWarnings=[];

        // ── Read raw values ─────────────────────────────────
        const nm    =san.name(String(row[0]||""));
        const rawCat=String(row[1]||"").trim();
        const ser   =san.serial(String(row[2]||""));
        const rawLoc=String(row[3]||"").trim();
        const rawSt =String(row[4]||"").trim();
        const rawDt =String(row[5]||"").trim();
        const rawCs =String(row[6]||"").trim();
        const rawLc =String(row[7]||"").trim();
        const rawNc =String(row[8]||"").trim();
        const notes =san.notes(String(row[9]||""));

        // ── Smart normalisation ─────────────────────────────
        const matchedCat=matchList(rawCat, cats);
        const matchedLoc=matchList(rawLoc, locs);
        const st  =normaliseStatus(rawSt);
        const nm2 =normaliseDate(rawDt);
        const cs  =normaliseCalStatus(rawCs);
        const lc  =normaliseDate(rawLc);
        const nc  =normaliseDate(rawNc);

        // If category/location was matched by partial/contains, warn but accept
        if(matchedCat&&matchedCat.toLowerCase()!==rawCat.toLowerCase()){
          rowWarnings.push("category '"+rawCat+"' auto-matched to '"+matchedCat+"'");
        }
        if(matchedLoc&&matchedLoc.toLowerCase()!==rawLoc.toLowerCase()){
          rowWarnings.push("location '"+rawLoc+"' auto-matched to '"+matchedLoc+"'");
        }

        // ── Validate ────────────────────────────────────────
        const errs=[];
        if(!V.name(nm))
          errs.push("name: must be 2–120 characters");

        if(!matchedCat)
          errs.push("category '"+san.text(rawCat)+"' not found. Valid: "+cats.join(", "));

        if(!V.serial(ser))
          errs.push("serial_number: use only letters, numbers, spaces, - _ . /  (max 60)");

        if(valid.find(v=>v.serial_number.toLowerCase()===ser.toLowerCase()))
          errs.push("serial_number '"+ser+"' duplicated within this file");

        if(STATE.equipment.find(eq=>eq.serial_number.toLowerCase()===ser.toLowerCase()))
          errs.push("serial_number '"+ser+"' already exists in inventory");

        if(!matchedLoc)
          errs.push("location '"+san.text(rawLoc)+"' not found. Valid: "+locs.join(", "));

        if(!V.status(st))
          errs.push("status '"+san.text(rawSt)+"': use one of — Functional & In Use, Functional but Not in Use, Non-Functional, Needs Repair, Obsolete");

        if(!nm2)
          errs.push("next_maintenance '"+san.text(rawDt)+"': use YYYY-MM-DD, DD/MM/YYYY or MM/DD/YYYY");

        if(!V.calStatus(cs))
          errs.push("calibration_status '"+san.text(rawCs)+"': use 'cal_required', 'yes', 'cal_not_required', or 'no'");

        if(cs==="cal_required"&&!nc)
          errs.push("next_calibration required when calibration_status is cal_required");

        if(rawLc&&!lc)
          errs.push("last_calibration '"+san.text(rawLc)+"': use YYYY-MM-DD, DD/MM/YYYY or MM/DD/YYYY");

        if(errs.length){
          errors.push({row:rn, msg:errs.join(" · "), warnings:rowWarnings});
        } else {
          if(rowWarnings.length)warnings.push({row:rn, msgs:rowWarnings});
          valid.push({
            id:uid(),
            name:nm,
            category:matchedCat,
            serial_number:ser,
            location:matchedLoc,
            status:st,
            next_maintenance:nm2,
            calibration_status:cs,
            last_calibration:lc||null,
            next_calibration:cs==="cal_required"?(nc||null):null,
            notes,
            last_updated:today(),
          });
        }
      });

      STATE.bulkResult={valid,errors,warnings};
      render();
    }catch(err){
      showToast("Failed to parse file: "+err.message,"error");
      console.error(err);
    }
  };
  reader.readAsArrayBuffer(file);
}

