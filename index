-- ── 4. AUDIT LOG TABLE ────────────────────────────────────────
-- Every create/update/delete is automatically logged.
-- This is required for medical equipment traceability.
CREATE TABLE IF NOT EXISTS audit_log (
  id          BIGSERIAL   PRIMARY KEY,
  table_name  TEXT        NOT NULL,
  record_id   TEXT        NOT NULL,
  action      TEXT        NOT NULL CHECK(action IN ('INSERT','UPDATE','DELETE')),
  user_id     UUID        REFERENCES auth.users(id),
  user_email  TEXT,
  old_data    JSONB,
  new_data    JSONB,
  changed_at  TIMESTAMPTZ NOT NULL DEFAULT NOW(),
  ip_hint     TEXT        -- populated by app if available
);

-- Index for fast lookups
CREATE INDEX IF NOT EXISTS idx_audit_record   ON audit_log(record_id);
CREATE INDEX IF NOT EXISTS idx_audit_user     ON audit_log(user_id);
CREATE INDEX IF NOT EXISTS idx_audit_time     ON audit_log(changed_at DESC);
CREATE INDEX IF NOT EXISTS idx_audit_table    ON audit_log(table_name);

-- Trigger function: fires on every equipment change
CREATE OR REPLACE FUNCTION log_equipment_change()
RETURNS TRIGGER AS $$
DECLARE
  v_user_email TEXT;
BEGIN
  SELECT email INTO v_user_email FROM auth.users WHERE id = auth.uid();

  IF (TG_OP = 'DELETE') THEN
    INSERT INTO audit_log(table_name,record_id,action,user_id,user_email,old_data,new_data)
    VALUES('equipment', OLD.id, 'DELETE', auth.uid(), v_user_email, to_jsonb(OLD), NULL);
    RETURN OLD;
  ELSIF (TG_OP = 'UPDATE') THEN
    INSERT INTO audit_log(table_name,record_id,action,user_id,user_email,old_data,new_data)
    VALUES('equipment', NEW.id, 'UPDATE', auth.uid(), v_user_email, to_jsonb(OLD), to_jsonb(NEW));
    RETURN NEW;
  ELSIF (TG_OP = 'INSERT') THEN
    INSERT INTO audit_log(table_name,record_id,action,user_id,user_email,old_data,new_data)
    VALUES('equipment', NEW.id, 'INSERT', auth.uid(), v_user_email, NULL, to_jsonb(NEW));
    RETURN NEW;
  END IF;
  RETURN NULL;
END;
$$ LANGUAGE plpgsql SECURITY DEFINER;

DROP TRIGGER IF EXISTS equipment_audit ON equipment;
CREATE TRIGGER equipment_audit
  AFTER INSERT OR UPDATE OR DELETE ON equipment
  FOR EACH ROW EXECUTE FUNCTION log_equipment_change();

