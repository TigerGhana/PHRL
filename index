/* ─── CHART ──────────────────────────────────────── */
function renderChart(){
  const canvas=document.getElementById("report-chart");if(!canvas)return;
  const legEl=document.getElementById("chart-legend");
  if(typeof Chart==="undefined"){if(legEl)legEl.innerHTML='<p style="text-align:center;color:var(--sub);font-size:13px">⚠️ Chart library not loaded. Check your connection.</p>';return;}
  if(STATE.chartInst){STATE.chartInst.destroy();STATE.chartInst=null;}
  const eq=STATE.equipment,total=eq.length||1;
  let labels=[],data=[],colors=[];
  const isMaint=STATE.report==="maintenance";
  if(STATE.report==="status"){
    const c={};eq.forEach(e=>{c[e.status]=(c[e.status]||0)+1;});
    Object.entries(c).forEach(([k,v],i)=>{labels.push(STATUS_CFG[k]?.label||k);data.push(v);colors.push(STATUS_CFG[k]?.bg||CHART_PAL[i%CHART_PAL.length]);});
  }else if(STATE.report==="location"){
    const c={};eq.forEach(e=>{c[e.location]=(c[e.location]||0)+1;});
    Object.entries(c).sort((a,b)=>b[1]-a[1]).forEach(([k,v],i)=>{labels.push(k);data.push(v);colors.push(CHART_PAL[i%CHART_PAL.length]);});
  }else if(STATE.report==="category"){
    const c={};eq.forEach(e=>{c[e.category]=(c[e.category]||0)+1;});
    Object.entries(c).sort((a,b)=>b[1]-a[1]).forEach(([k,v],i)=>{labels.push(k);data.push(v);colors.push(CHART_PAL[i%CHART_PAL.length]);});
  }else{
    const ov=eq.filter(e=>daysDiff(e.next_maintenance)<0).length,up=eq.filter(e=>{const d=daysDiff(e.next_maintenance);return d>=0&&d<=30;}).length,ok=eq.length-ov-up;
    labels=["Overdue","Upcoming 30d","On Schedule"];data=[ov,up,ok];colors=["#ef4444","#f59e0b","#22c55e"];
  }
  const pct=v=>((v/total)*100).toFixed(1)+"%";
  STATE.chartInst=new Chart(canvas,{
    type:isMaint?"bar":"doughnut",
    data:{labels,datasets:[{data,backgroundColor:isMaint?colors.map(c=>c+"cc"):colors,borderColor:"#fff",borderWidth:isMaint?0:3,hoverOffset:isMaint?0:10,borderRadius:isMaint?8:0}]},
    options:{responsive:true,maintainAspectRatio:false,cutout:isMaint?undefined:"58%",
      plugins:{legend:{display:false},tooltip:{backgroundColor:"rgba(15,23,42,.9)",titleFont:{family:"Nunito",size:13,weight:"800"},bodyFont:{family:"Nunito",size:12},padding:12,cornerRadius:10,
        callbacks:{label:ctx=>" "+(isMaint?ctx.raw:ctx.parsed)+" item"+((isMaint?ctx.raw:ctx.parsed)!==1?"s":"")+" — "+pct(isMaint?ctx.raw:ctx.parsed)}}},
      scales:isMaint?{y:{beginAtZero:true,ticks:{font:{family:"Nunito",size:11},stepSize:1},grid:{color:"rgba(0,0,0,.05)"}},x:{ticks:{font:{family:"Nunito",size:11}},grid:{display:false}}}:undefined},
  });
  if(legEl){
    legEl.innerHTML='<div style="display:flex;justify-content:space-between;padding:0 10px 6px;border-bottom:1px solid var(--border);margin-bottom:4px"><span style="font-size:9px;font-weight:800;color:var(--sub);text-transform:uppercase">Category</span><div style="display:flex;gap:16px"><span style="font-size:9px;font-weight:800;color:var(--sub);text-transform:uppercase">Count</span><span style="font-size:9px;font-weight:800;color:var(--sub);text-transform:uppercase">Share</span></div></div>'+
    labels.map((lbl,i)=>'<div style="display:flex;align-items:center;justify-content:space-between;padding:8px 10px;border-radius:8px;background:'+(i%2===0?"#f8fafc":"#fff")+'"><div style="display:flex;align-items:center;gap:8px;flex:1;min-width:0"><div style="width:12px;height:12px;border-radius:3px;background:'+colors[i]+';flex-shrink:0"></div><span style="font-size:12.5px;font-weight:600;color:var(--text);overflow:hidden;text-overflow:ellipsis;white-space:nowrap">'+esc(lbl)+'</span></div><div style="display:flex;align-items:center;gap:10px;flex-shrink:0"><span style="font-size:14px;font-weight:900;color:var(--text)">'+data[i]+'</span><span style="font-size:11px;font-weight:700;color:'+colors[i]+';background:'+colors[i]+'1a;padding:3px 8px;border-radius:99px">'+pct(data[i])+'</span></div></div>').join("");
  }
}

