═══════════════════════════════════════════════════════ */
async function loadServiceHistory(equipId){
  STATE.historyItem=STATE.equipment.find(e=>e.id===equipId)||STATE.detail;
  STATE.historyLogs=[];
  STATE.modal="serviceHistory";
  STATE.detail=null;
  render();
  if(!STATE.offline){
    try{
      const logs=await sb.query("audit_log",
        "record_id=eq."+encodeURIComponent(equipId)+"&order=changed_at.desc&limit=100");
      if(Array.isArray(logs)){
        STATE.historyLogs=logs;
        render();
      }
    }catch(e){showToast("Could not load history: "+e.message,"error");}
  }
}

/* ═══════════════════════════════════════════════════════
   15. TOAST
═══════════════════════════════════════════════════════ */
function showToast(msg,type){
  document.querySelectorAll(".toast").forEach(t=>t.remove());
  const BG={success:"#dcfce7",error:"#fee2e2",info:"#1e293b"};
  const TC={success:"#166534",error:"#991b1b",info:"#fff"};
  const t=document.createElement("div");
  t.className="toast";t.setAttribute("role","status");t.setAttribute("aria-live","polite");
  t.style.cssText="position:fixed;bottom:90px;left:50%;transform:translateX(-50%);background:"+(BG[type]||BG.info)+";color:"+(TC[type]||TC.info)+";font-family:Nunito,sans-serif;font-weight:700;font-size:13px;padding:11px 22px;border-radius:99px;z-index:999;max-width:320px;text-align:center;box-shadow:0 6px 20px rgba(0,0,0,.18);pointer-events:none;border:"+(type!=="info"?"1.5px solid "+(TC[type]||""):"none")+";animation:fadeIn .2s ease";
  t.textContent=String(msg||"").slice(0,200);
  document.body.appendChild(t);
  setTimeout(()=>{t.style.opacity="0";t.style.transition="opacity .3s";setTimeout(()=>t.remove(),300);},2800);
}

