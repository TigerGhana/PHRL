function fField(label,id,type,value,req){
  return '<div style="display:flex;flex-direction:column;gap:4px">'+
    '<label style="font-size:12px;font-weight:700;color:var(--sub);text-transform:uppercase;letter-spacing:.5px" for="'+esc(id)+'">'+esc(label)+(req?' <span style="color:var(--red)">*</span>':"")+'</label>'+
    '<input class="inp" id="'+esc(id)+'" type="'+esc(type)+'" value="'+esc(value)+'" placeholder="'+esc(label)+'" maxlength="'+(type==="date"?10:120)+'"/>'+
    '<span class="field-err" id="err-'+esc(id)+'" role="alert"></span></div>';
}

function toggleCalDates(val){
  const wrap=document.getElementById("cal-dates-wrap");
  const inner=wrap?.querySelector("div");
  const hint=inner?.querySelector("span");
  const req=val==="cal_required";
  if(wrap){wrap.style.opacity=req?"1":".35";wrap.style.pointerEvents=req?"auto":"none";}
  if(inner){inner.style.background=req?"#fef3c7":"#f8fafc";inner.style.borderColor=req?"var(--amber)":"var(--border)";}
  if(hint){hint.textContent=req?"🔧 Fill in calibration dates:":"ℹ️ Select Calibration Required above to enable";}
}

