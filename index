// Safety check: warn if service_role key accidentally used
// service_role JWTs contain "role":"service_role" in their payload
(()=>{
  try{
    if(!SUPABASE_ANON.includes("YOUR_ANON")&&SUPABASE_ANON.includes(".")){
      const payload=JSON.parse(atob(SUPABASE_ANON.split(".")[1].replace(/-/g,"+").replace(/_/g,"/")));
      if(payload.role==="service_role"){
        document.body.innerHTML='<div style="font-family:Nunito,sans-serif;padding:40px;max-width:500px;margin:0 auto;text-align:center"><div style="font-size:48px;margin-bottom:16px">🚨</div><h1 style="color:#ef4444;font-size:22px;margin-bottom:12px">SECURITY ERROR</h1><p style="color:#1e293b;font-size:15px;line-height:1.6">You have used the <strong>service_role</strong> key instead of the <strong>anon/public</strong> key. This bypasses all Row Level Security and exposes your entire database.<br/><br/>Replace SUPABASE_ANON with your <strong>anon public key</strong> from Supabase → Settings → API.</p></div>';
        throw new Error("CRITICAL: service_role key detected in frontend — app halted");
      }
    }
  }catch(e){if(e.message.includes("CRITICAL"))throw e;/* ignore decode errors */}
})();

if(SUPABASE_URL.includes("YOUR_PROJECT")||SUPABASE_ANON.includes("YOUR_ANON")){
  STATE.offline=true;STATE.loading=false;
  STATE.equipment=JSON.parse(JSON.stringify(SEED));
  render();
  // Show pending queue count on load
  const pq=loadP(QUEUE_KEY,[]);
