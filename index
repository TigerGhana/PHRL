/* ─── EQUIPMENT DETAIL (read-only) ──────────────── */
function renderDetail(){
  const e=STATE.detail;if(!e)return"";
  const sc=STATUS_CFG[e.status]||{label:e.status,bg:"#94a3b8",text:"#fff",icon:"?"};
  const diff=daysDiff(e.next_maintenance);
  const maintSt=diff<0?{txt:"Overdue by "+Math.abs(diff)+"d",color:"var(--red)",bg:"var(--red-lt)"}:diff<=30?{txt:"Due in "+diff+"d",color:"var(--amber)",bg:"var(--amber-lt)"}:{txt:"On schedule",color:"var(--green-dk)",bg:"var(--green-lt)"};
  const calRequired=e.calibration_status==="cal_required";
  const calDiff=calRequired&&e.next_calibration?daysDiff(e.next_calibration):null;
  const calSt=calDiff===null?null:calDiff<0?{txt:"Overdue by "+Math.abs(calDiff)+"d",color:"#b45309",bg:"#fef3c7"}:calDiff<=30?{txt:"Due in "+calDiff+"d",color:"#d97706",bg:"#fef3c7"}:{txt:"On schedule",color:"var(--green-dk)",bg:"var(--green-lt)"};

  const infoRows=[
    {ico:"🏷️",bg:"#eff6ff",label:"Category",          value:e.category},
    {ico:"🔢",bg:"#faf5ff",label:"Serial / Asset No.", value:e.serial_number},
    {ico:"📍",bg:"#fff5f5",label:"Location",           value:e.location},
    {ico:"📅",bg:"#fffbeb",label:"Next Maintenance",   value:fmtDate(e.next_maintenance)},
    {ico:"🔄",bg:"#f0f9ff",label:"Maintenance Recurrence",value:recurrenceLabel(e.maintenance_interval||"90")},
