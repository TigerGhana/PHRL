    ...(calRequired&&e.next_calibration?[{ico:"📆",bg:calSt?.bg||"#f8fafc",label:"Next Calibration",value:fmtDate(e.next_calibration),vc:calSt?.color}]:[]),
    ...(calSt?[{ico:"📊",bg:calSt.bg,label:"Calibration Alert",value:calSt.txt,vc:calSt.color}]:[]),
    {ico:"📝",bg:"#f8fafc",label:"Notes",value:e.notes||"—"},
    {ico:"🔄",bg:"#f0fdf4",label:"Last Updated",value:fmtDate(e.last_updated)},
  ];

  return '<div class="fullscreen" role="dialog" aria-modal="true">'+
    '<div class="fs-header"><button class="fs-back" id="btn-close-detail">← Back</button><span style="font-weight:800;font-size:16px;color:var(--text);flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">'+esc(e.name)+'</span></div>'+
