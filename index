<body>
<div id="offline-bar">⚠️ OFFLINE / DEMO MODE — Not for production use. Configure Supabase credentials. <a href="#" id="offline-bar-guide" style="color:#fff;font-weight:900;text-decoration:underline;margin-left:8px">Setup Guide →</a></div>
<div id="app"></div>
<script>
"use strict";
/* ═══════════════════════════════════════════════════════
   1. SECURITY & STORAGE UTILITIES
═══════════════════════════════════════════════════════ */
function esc(s){
  return String(s==null?"":s)
    .replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;")
    .replace(/"/g,"&quot;").replace(/'/g,"&#x27;").replace(/\//g,"&#x2F;");
}
const san={
  text:  s=>String(s==null?"":s).replace(/[\x00-\x08\x0B\x0C\x0E-\x1F\x7F]/g,"").replace(/<[^>]*>/g,"").trim().slice(0,200),
  name:  s=>String(s==null?"":s).replace(/[\x00-\x08\x0B\x0C\x0E-\x1F\x7F]/g,"").replace(/<[^>]*>/g,"").trim().slice(0,120),
  serial:s=>String(s==null?"":s).replace(/[^A-Za-z0-9 \-_./]/g,"").trim().slice(0,60),
  notes: s=>String(s==null?"":s).replace(/[\x00-\x08\x0B\x0C\x0E-\x1F\x7F]/g,"").replace(/<[^>]*>/g,"").trim().slice(0,500),
  date:  s=>{const m=(/^(\d{4}-(?:0[1-9]|1[0-2])-(?:0[1-9]|[12]\d|3[01]))/).exec(String(s==null?"":s).trim());return m?m[1]:"";},
  email: s=>String(s==null?"":s).toLowerCase().replace(/[^a-z0-9@._+\-]/g,"").slice(0,120),
  num:   s=>{const n=parseInt(String(s==null?"":s));return isNaN(n)?0:n;},
};
const V={
  name:      v=>v.trim().length>=2&&v.trim().length<=120,
  serial:    v=>/^[A-Za-z0-9 \-_./]{1,60}$/.test(v.trim()),
  email:     v=>/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v.trim()),
  date:      v=>/^\d{4}-(0[1-9]|1[0-2])-(0[1-9]|[12]\d|3[01])$/.test(v),
  status:    v=>["functional_in_use","functional_not_in_use","non_functional","needs_repair","obsolete"].includes(v),
  calStatus: v=>["cal_required","cal_not_required"].includes(v),
};
// Progressive login security — exponential backoff + lockout countdown
const _loginState={failures:0,lockedUntil:0,delays:[0,1000,2000,4000,8000,15000]};
function checkRate(){
  const now=Date.now();
  if(_loginState.lockedUntil>now){
    const secs=Math.ceil((_loginState.lockedUntil-now)/1000);
    return{ok:false,wait:secs,msg:"Too many failed attempts. Wait "+secs+"s."};
  }
  return{ok:true,wait:0};
}
function recordLoginFailure(){
  _loginState.failures=Math.min(_loginState.failures+1,_loginState.delays.length-1);
  _loginState.lockedUntil=Date.now()+(_loginState.delays[_loginState.failures]||15000);
}
function recordLoginSuccess(){_loginState.failures=0;_loginState.lockedUntil=0;}

// Storage — loadP/saveP use localStorage (persistent), loadS/saveS use sessionStorage (auth)
// Safe JSON parse — prevents prototype pollution from tampered storage values
function safeJSON(str,fallback){
  try{
    const parsed=JSON.parse(str);
    // Reject any object with __proto__ or constructor pollution attempt
    if(parsed&&typeof parsed==="object"&&("__proto__" in parsed||"constructor" in parsed)){
      console.warn("Prototype pollution attempt blocked in storage");
      return fallback;
    }
    return parsed;
  }catch{return fallback;}
}
function loadP(k,fb){try{const v=localStorage.getItem(k);return v?safeJSON(v,fb):fb;}catch{return fb;}}
function saveP(k,v){try{localStorage.setItem(k,JSON.stringify(v));}catch{}}
function loadS(k,fb){try{const v=sessionStorage.getItem(k);return v?safeJSON(v,fb):fb;}catch{return fb;}}
function saveS(k,v){try{sessionStorage.setItem(k,JSON.stringify(v));}catch{}}

/* ── Offline write queue ────────────────────────────────────────
   Saves pending writes to localStorage when offline.
   On reconnect, flushes them to Supabase in order.
   Prevents silent data loss during network interruptions.
─────────────────────────────────────────────────────────────── */
const QUEUE_KEY="medinv_offline_queue";
function enqueueWrite(op){
  const q=loadP(QUEUE_KEY,[]);
  q.push({...op, ts:Date.now(), id:uid()});
  saveP(QUEUE_KEY,q);
  showSyncBanner(q.length);
}
function showSyncBanner(n){
  let bar=document.getElementById("sync-bar");
  if(!bar){bar=document.createElement("div");bar.id="sync-bar";bar.style.cssText="position:fixed;bottom:70px;left:50%;transform:translateX(-50%);background:#1e293b;color:#fff;font-size:12px;font-weight:700;padding:8px 18px;border-radius:99px;z-index:500;display:flex;align-items:center;gap:8px;box-shadow:0 4px 14px rgba(0,0,0,.25);max-width:90vw;font-family:Nunito,sans-serif";document.body.appendChild(bar);}
  if(n>0){bar.innerHTML='⏳ '+n+' pending change'+(n>1?"s":"")+'  <button onclick="flushQueue()" style="background:var(--teal);border:none;color:#fff;border-radius:8px;padding:3px 10px;cursor:pointer;font-family:Nunito,sans-serif;font-size:11px;font-weight:700">Sync Now</button>';bar.style.display="flex";}
  else{bar.style.display="none";}
}
async function flushQueue(){
  const q=loadP(QUEUE_KEY,[]);
  if(!q.length)return;
  const remaining=[];
  for(const op of q){
    try{
      if(op.type==="upsert"){
        const i={...op.item};const isNew=i._isNew;delete i._isNew;
        if(isNew)await sb.insert("equipment",i);
        else await sb.safeUpdate("equipment",i.id,i,i.last_updated);
      } else if(op.type==="delete"){
        // Soft-delete: mark is_deleted=true (preserves audit trail, matches online path)
        const knownDate=(op.item&&op.item.last_updated)||today();
        await sb.safeUpdate("equipment",op.id,{is_deleted:true,last_updated:knownDate},knownDate);
      } else if(op.type==="setting"){
        await saveSettingToDB(op.key,op.val);
      }
    }catch(e){remaining.push(op);}
  }
  saveP(QUEUE_KEY,remaining);
  showSyncBanner(remaining.length);
  if(remaining.length<q.length){await fetchEquipment();showToast("✅ "+(q.length-remaining.length)+" pending changes synced","success");}
  else if(remaining.length>0){showToast("⚠️ Some changes couldn't sync — will retry","error");}
}
// Try flushing queue whenever network comes back
window.addEventListener("online",()=>{
  STATE.offline=false;
  const q=loadP(QUEUE_KEY,[]);
  if(q.length){showToast("Network restored — syncing "+q.length+" pending change(s)…","info");flushQueue();}
});
window.addEventListener("offline",()=>{STATE.offline=true;});

/* ═══════════════════════════════════════════════════════
   2. CONFIGURATION — replace with your Supabase values
   ─────────────────────────────────────────────────────
   SECURITY NOTES:
   • Use ONLY the "anon / public" key — NEVER the service_role key
   • The anon key is safe to expose here because:
     - RLS policies restrict what it can access
     - REVOKE statements block all anon writes
   • The service_role key bypasses ALL RLS — NEVER put it here
   • Rotate the anon key in Supabase if you suspect compromise:
     Settings → API → Reveal → Rotate
