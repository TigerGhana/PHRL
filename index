}

/* ─── MAINTENANCE TAB ────────────────────────────── */
function renderMaintenance(){
  const s=getStats();const admin=isAdmin();
  function maintCard(e,isOverdue){
    const diff=isOverdue?Math.abs(daysDiff(e.next_maintenance)):daysDiff(e.next_maintenance);
    const sc=STATUS_CFG[e.status]||{label:e.status,bg:"#94a3b8",text:"#fff",icon:"?"};
    const cls=isOverdue?"mcard-red":"mcard-amb";
    const pill=isOverdue
      ?'<span style="font-size:11px;font-weight:800;color:var(--red);background:var(--red-lt);padding:3px 8px;border-radius:99px">⚠️ '+diff+'d overdue</span>'
      :'<span style="font-size:11px;font-weight:800;color:var(--amber);background:var(--amber-lt);padding:3px 8px;border-radius:99px">🕐 '+diff+'d left</span>';
    const btnColor=isOverdue?"btn-red":"btn-amber";
    return '<div class="'+cls+'">'+
      '<div style="display:flex;justify-content:space-between;align-items:flex-start;gap:8px;margin-bottom:8px"><span style="font-weight:800;color:var(--text);font-size:15px">'+esc(e.name)+'</span>'+pill+'</div>'+
      '<div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:8px">'+
        '<div style="display:flex;flex-direction:column;gap:2px">'+
          '<span class="status-label">⚙️ Functional</span>'+
          '<span class="badge" style="background:'+sc.bg+';color:'+sc.text+';font-size:10px">'+sc.icon+' '+esc(sc.label)+'</span>'+
        '</div>'+
        '<div style="display:flex;flex-direction:column;gap:2px">'+
          '<span class="status-label">⏰ Calibration</span>'+
          calBadge(e)+
        '</div>'+
      '</div>'+
      '<div style="font-size:12px;color:var(--sub);margin-bottom:8px">📍 '+esc(e.location)+' · '+(isOverdue?"Was: ":"Due: ")+fmtDate(e.next_maintenance)+'</div>'+
      (admin
        ?'<button class="btn '+btnColor+' btn-mark-done" data-id="'+esc(e.id)+'" style="font-size:13px;padding:10px">✓ Mark Maintenance Done (+90 days)</button>'
        :'<div class="ro-notice">🔒 Admin required to update</div>')+
    '</div>';
  }
  function calCard(e,isOverdue){
    const diff=isOverdue?Math.abs(daysDiff(e.next_calibration)):daysDiff(e.next_calibration);
    const sc=STATUS_CFG[e.status]||{label:e.status,bg:"#94a3b8",text:"#fff",icon:"?"};
    const cls=isOverdue?"mcard-red":"mcard-amb";
    const pill=isOverdue
      ?'<span style="font-size:11px;font-weight:800;color:#b45309;background:#fef3c7;padding:3px 8px;border-radius:99px">⏰ '+diff+'d overdue</span>'
      :'<span style="font-size:11px;font-weight:800;color:#d97706;background:#fef3c7;padding:3px 8px;border-radius:99px">🔧 '+diff+'d left</span>';
    return '<div class="'+cls+'" style="border-color:'+(isOverdue?"#b45309":"#d97706")+';background:'+(isOverdue?"#fefce8":"#fffbeb")+'">'+
      '<div style="display:flex;justify-content:space-between;align-items:flex-start;gap:8px;margin-bottom:8px"><span style="font-weight:800;color:var(--text);font-size:15px">'+esc(e.name)+'</span>'+pill+'</div>'+
      '<div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:8px">'+
        '<div style="display:flex;flex-direction:column;gap:2px">'+
          '<span class="status-label">⚙️ Functional</span>'+
          '<span class="badge" style="background:'+sc.bg+';color:'+sc.text+';font-size:10px">'+sc.icon+' '+esc(sc.label)+'</span>'+
        '</div>'+
        '<div style="display:flex;flex-direction:column;gap:2px">'+
          '<span class="status-label">⏰ Calibration</span>'+
          calBadge(e)+
        '</div>'+
      '</div>'+
      '<div style="font-size:12px;color:var(--sub);margin-bottom:8px">📍 '+esc(e.location)+' · Last cal: '+fmtDate(e.last_calibration)+' · Due: '+fmtDate(e.next_calibration)+'</div>'+
      (admin
        ?'<button class="btn btn-mark-cal-done" data-id="'+esc(e.id)+'" style="font-size:13px;padding:10px;background:'+(isOverdue?"#b45309":"#d97706")+';color:#fff;border:none;border-radius:12px;cursor:pointer;font-family:Nunito,sans-serif;font-weight:700;width:100%;display:flex;align-items:center;justify-content:center;gap:6px">⏰ Mark Calibration Done (+1 year)</button>'
        :'<div class="ro-notice">🔒 Admin required to update</div>')+
    '</div>';
  }

  const overdueHTML=s.overdueList.length?s.overdueList.map(e=>maintCard(e,true)).join(""):'<div class="mcard-grn">🎉 No maintenance overdue!</div>';
  const upcomingHTML=s.upcoming.length?s.upcoming.map(e=>maintCard(e,false)).join(""):'<p style="color:var(--sub);font-size:14px;padding:6px 0">No maintenance due in 30 days.</p>';
  const calOverdueHTML=s.calOverdueList.length?s.calOverdueList.map(e=>calCard(e,true)).join(""):'<div class="mcard-grn">✅ No calibration overdue!</div>';
  const calUpcomingHTML=s.calUpcomingList.length?s.calUpcomingList.map(e=>calCard(e,false)).join(""):'<p style="color:var(--sub);font-size:14px;padding:6px 0">No calibrations due in 30 days.</p>';

  return '<div class="screen">'+
    '<div class="page-hero"><h1>🔧 Maintenance & Calibration</h1><p>'+s.overdueList.length+' maint. overdue · '+s.calOverdueList.length+' cal. overdue</p></div>'+
