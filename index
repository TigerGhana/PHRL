-- ═══════════════════════════════════════════════════════════════


-- ── 1. PROFILES TABLE (roles per user) ────────────────────────
-- Every Supabase Auth user gets a profile with a role.
-- Roles: admin | engineer | technician | viewer
CREATE TABLE IF NOT EXISTS profiles (
  id         UUID        PRIMARY KEY REFERENCES auth.users(id) ON DELETE CASCADE,
  email      TEXT        NOT NULL,
  full_name  TEXT        DEFAULT '',
  role       TEXT        NOT NULL DEFAULT 'viewer'
               CHECK(role IN ('admin','engineer','technician','viewer')),
  department TEXT        DEFAULT '',
  created_at TIMESTAMPTZ DEFAULT NOW(),
  updated_at TIMESTAMPTZ DEFAULT NOW()
);

-- ── SECURITY DEFINER helper (avoids circular RLS) ─────────────
-- This function reads a user role WITHOUT triggering RLS,
-- preventing the infinite-loop error on the profiles table.
CREATE OR REPLACE FUNCTION get_my_role()
RETURNS TEXT AS $$
  SELECT role FROM profiles WHERE id = auth.uid();
$$ LANGUAGE sql STABLE SECURITY DEFINER;

-- ── Auto-create profile on new user ──────────────────────────
-- Works for BOTH signup AND Supabase Dashboard user creation.
CREATE OR REPLACE FUNCTION handle_new_user()
RETURNS TRIGGER AS $$
BEGIN
  INSERT INTO profiles (id, email, role)
  VALUES (
    NEW.id,
    COALESCE(NEW.email, NEW.raw_user_meta_data->>'email', 'unknown@hospital.com'),
    'viewer'
  )
  ON CONFLICT (id) DO NOTHING;
  RETURN NEW;
END;
$$ LANGUAGE plpgsql SECURITY DEFINER SET search_path = public;

DROP TRIGGER IF EXISTS on_auth_user_created ON auth.users;
CREATE TRIGGER on_auth_user_created
  AFTER INSERT ON auth.users
  FOR EACH ROW EXECUTE FUNCTION handle_new_user();

